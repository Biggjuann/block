# ---- Server ----
PORT=3000

# ---- Database ----
# Path to the SQLite database file. On Railway, point this at a mounted
# volume (e.g. /data/blocktrades.sqlite) so trades persist across deploys.
DB_PATH=./data/blocktrades.sqlite

# ---- Schwab API auth ----
# How the access token is sourced:
#   shared  -> fetch a live token from SCHWAB_TOKEN_URL (token-sharing app)
#   token   -> use the static SCHWAB_TOKEN below
#   auto    -> use shared if SCHWAB_TOKEN_URL is set, else static, else simulator
SCHWAB_AUTH_MODE=shared

# Base URL for the Schwab API (override only if proxying).
SCHWAB_BASE_URL=https://api.schwabapi.com

# Endpoint of your other app that returns the current Schwab access token.
# Expected response: JSON { "access_token": "...", "expires_in": 1800 }
SCHWAB_TOKEN_URL=

# Bearer key sent as `Authorization: Bearer <key>` to SCHWAB_TOKEN_URL.
SCHWAB_TOKEN_SHARE_KEY=

# Static access token, used when SCHWAB_AUTH_MODE=token (or as a fallback).
SCHWAB_TOKEN=

# ---- Universe ----
# Comma-separated watchlist. Leave empty to use the curated universe in
# src/universe.js (liquid US equities + ETFs).
SCHWAB_SYMBOLS=

# ---- Block-trade thresholds (define the tape columns as size ranges) ----
# Comma-separated ascending thresholds. Each column spans from its threshold
# up to the next; the last column is open-ended.
BLOCK_THRESHOLDS=50000,400000,500000,800000

# Min share size persisted as a block (defaults to the smallest threshold).
BLOCK_MIN_SIZE=50000

# Min share size to appear in the dashboard "Prints" feed.
PRINT_MIN_SIZE=400000

# Force simulator mode even if a token source is configured (true/false).
FORCE_SIMULATOR=false

# Keep the simulator generating tape 24/7 (e.g. for demos). Off by default so
# simulated tape pauses outside US market hours, matching reality.
SIMULATE_ALWAYS=false

# ---- Relative volume (%ADV) ----
# How often to refresh Schwab fundamentals (average daily volume) in ms.
FUNDAMENTALS_REFRESH_MS=900000

# ---- Server-side "whale" alerts ----
# A block clearing either threshold triggers an alert (broadcast to browsers
# and pushed to Discord if a webhook is set). Set a threshold to 0 to disable it.
ALERT_MIN_NOTIONAL=25000000
ALERT_MIN_PCT_ADV=5

# Optional Discord webhook URL for off-screen push notifications.
DISCORD_WEBHOOK_URL=
