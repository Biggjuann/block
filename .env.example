# ---- Server ----
PORT=3000

# ---- Database ----
# Path to the SQLite database file. On Railway, point this at a mounted
# volume (e.g. /data/blocktrades.sqlite) so trades persist across deploys.
DB_PATH=./data/blocktrades.sqlite

# ---- Schwab API ----
# Shared OAuth access token used to authenticate against the Schwab
# streaming + market data APIs. When omitted, the app runs in SIMULATOR
# mode and generates realistic block-trade tape so the UI is fully live.
SCHWAB_TOKEN=

# Comma-separated watchlist of symbols to stream from Schwab.
SCHWAB_SYMBOLS=SPY,QQQ,TSLA,IWM,AAPL,NVDA,MSFT,GLD,HYG,ORCL,AMZN,PFE,NIO,HIVE,BITF

# ---- Block-trade thresholds ----
# Minimum share size for a trade to be persisted as a "block trade".
BLOCK_MIN_SIZE=50000

# Minimum share size for a trade to show in the dashboard "Prints" feed.
PRINT_MIN_SIZE=400000

# Force simulator mode even if a token is present (true/false).
FORCE_SIMULATOR=false
